#!/bin/sh
# Pre-commit hook: lint staged files + typecheck
# Runs on every commit

set -e

echo "🔍 Running pre-commit checks..."

# Lint only staged files (JS/TS/TSX)
echo "  → ESLint on staged files..."
npx lint-staged

# TypeScript type check (full project)
echo "  → TypeScript type check..."
npm run typecheck

echo "✅ Pre-commit checks passed!"
