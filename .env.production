# ================================================================
# Multi-Model Agent Platform — Production Environment Template
# ================================================================
# Copy this file to .env (or use a secret manager) and fill in all
# <PLACEHOLDER> values before deploying to production.
# ================================================================

# ———————————————————————————————————————————————————————————————
# 1. Application
# ———————————————————————————————————————————————————————————————
APP_ENV=production
APP_NAME="Multi-Model Agent Platform"
APP_URL=https://<YOUR_DOMAIN>
APP_PORT=3000
APP_SECRET=<GENERATE_RANDOM_64_HEX>

# ———————————————————————————————————————————————————————————————
# 2. Database (PostgreSQL)
# ———————————————————————————————————————————————————————————————
DB_HOST=<DB_HOST>
DB_PORT=5432
DB_NAME=agent_platform
DB_USER=app_user
DB_PASSWORD=<STRONG_DB_PASSWORD>
DB_SSL_MODE=require
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT=30000

# ———————————————————————————————————————————————————————————————
# 3. Redis (Cache + Session + Rate Limiting)
# ———————————————————————————————————————————————————————————————
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>
REDIS_DB=0
REDIS_SSL=true
REDIS_TLS_CA_CERT=/etc/ssl/certs/ca-certificates.crt
REDIS_CONNECT_TIMEOUT=5000

# ———————————————————————————————————————————————————————————————
# 4. AI Model Providers
# ———————————————————————————————————————————————————————————————
# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_KEY>
OPENAI_ORG_ID=<YOUR_OPENAI_ORG>

# Anthropic
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_KEY>

# Google Gemini
GOOGLE_API_KEY=<YOUR_GOOGLE_KEY>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<RESOURCE>.openai.azure.com
AZURE_OPENAI_API_KEY=<YOUR_AZURE_KEY>
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Mistral
MISTRAL_API_KEY=<YOUR_MISTRAL_KEY>

# Cohere
COHERE_API_KEY=<YOUR_COHERE_KEY>

# ———————————————————————————————————————————————————————————————
# 5. Authentication & Authorization
# ———————————————————————————————————————————————————————————————
# JWT
JWT_SECRET=<GENERATE_RANDOM_64_HEX>
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# OAuth2 / SSO (optional)
GOOGLE_CLIENT_ID=<OAUTH_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<OAUTH_CLIENT_SECRET>
GITHUB_CLIENT_ID=<GITHUB_CLIENT_ID>
GITHUB_CLIENT_SECRET=<GITHUB_CLIENT_SECRET>

# MFA / TOTP
TOTP_ISSUER="Multi-Model Agent Platform"

# ———————————————————————————————————————————————————————————————
# 6. Object Storage (S3-compatible)
# ———————————————————————————————————————————————————————————————
S3_ENDPOINT=https://s3.<REGION>.amazonaws.com
S3_BUCKET=agent-platform-prod
S3_ACCESS_KEY_ID=<AWS_ACCESS_KEY>
S3_SECRET_ACCESS_KEY=<AWS_SECRET_KEY>
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false
S3_UPLOAD_MAX_SIZE=104857600

# ———————————————————————————————————————————————————————————————
# 7. Monitoring, Logging & Tracing
# ———————————————————————————————————————————————————————————————
# Structured logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# OpenTelemetry / Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=https://<JAEGER_COLLECTOR>:4318
OTEL_SERVICE_NAME=agent-platform-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Prometheus metrics
METRICS_PORT=9090
METRICS_PATH=/metrics

# Sentry error tracking (required for production)
SENTRY_DSN=<SENTRY_DSN_URL>
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=<GIT_COMMIT_SHA_OR_RELEASE_TAG>
SENTRY_TRACES_SAMPLE_RATE=0.1

# Client-side Sentry (required for browser error tracking)
NEXT_PUBLIC_SENTRY_DSN=<SENTRY_DSN_URL>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.0

# Sentry source map upload (CI/CD only)
SENTRY_AUTH_TOKEN=<SENTRY_AUTH_TOKEN>
SENTRY_ORG=<SENTRY_ORG_SLUG>
SENTRY_PROJECT=<SENTRY_PROJECT_SLUG>

# --- Datadog Real User Monitoring (RUM) ---
NEXT_PUBLIC_DD_RUM_ENABLED=true
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=<DATADOG_RUM_APP_ID>
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=<DATADOG_RUM_CLIENT_TOKEN>
NEXT_PUBLIC_DD_RUM_SITE=datadoghq.com
NEXT_PUBLIC_DD_RUM_ENV=production
NEXT_PUBLIC_DD_RUM_SERVICE=agent-platform-web
NEXT_PUBLIC_DD_RUM_VERSION=<GIT_COMMIT_SHA_OR_RELEASE_TAG>
NEXT_PUBLIC_DD_RUM_SAMPLE_RATE=100
NEXT_PUBLIC_DD_RUM_SESSION_REPLAY_SAMPLE_RATE=10

# ———————————————————————————————————————————————————————————————
# 8. Security
# ———————————————————————————————————————————————————————————————
# CORS
CORS_ORIGIN=https://<YOUR_DOMAIN>
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Argon2id password hashing (memory in KiB)
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Encryption at rest
ENCRYPTION_KEY=<32_BYTE_BASE64_KEY>

# ———————————————————————————————————————————————————————————————
# 9. Background Jobs / Message Queue
# ———————————————————————————————————————————————————————————————
BULL_REDIS_URL=rediss://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
QUEUE_PREFIX=bull
QUEUE_DEFAULT_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# ———————————————————————————————————————————————————————————————
# 10. Feature Flags
# ———————————————————————————————————————————————————————————————
FEATURE_STREAMING_RESPONSES=true
FEATURE_AGENT_COLLABORATION=true
FEATURE_RAG_KNOWLEDGE_BASE=true
FEATURE_AUDIT_LOG=true
FEATURE_MFA_REQUIRED=false

# ———————————————————————————————————————————————————————————————
# 11. SMTP / Email
# ———————————————————————————————————————————————————————————————
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<SENDGRID_API_KEY>
SMTP_FROM=noreply@<YOUR_DOMAIN>
SMTP_TLS=true

# ———————————————————————————————————————————————————————————————
# 12. Health Checks
# ———————————————————————————————————————————————————————————————
HEALTH_CHECK_PORT=3001
HEALTH_CHECK_PATH=/health
READINESS_TIMEOUT=5000

# ———————————————————————————————————————————————————————————————
# 13. TLS / SSL (for internal mTLS if needed)
# ———————————————————————————————————————————————————————————————
TLS_CERT_PATH=/etc/certs/server.crt
TLS_KEY_PATH=/etc/certs/server.key
TLS_CA_PATH=/etc/certs/ca.crt

# ================================================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Use: git update-index --skip-worktree .env.production
# Or add to .gitignore
# ================================================================
