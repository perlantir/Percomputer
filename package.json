{
  "name": "multi-model-agent-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Perplexity Computer clone — Multi-model, multi-agent orchestration platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/",
    "test:unit:watch": "vitest tests/",
    "test:unit:coverage": "vitest run tests/ --coverage",
    "test:unit:coverage:watch": "vitest tests/ --coverage",
    "test:unit:coverage:html": "vitest run tests/ --coverage && open coverage/index.html",
    "test:unit:ci": "vitest run tests/ --coverage --reporter=default --reporter=junit --outputFile=test-results/junit.xml",
    "test:e2e:coverage": "echo 'Playwright E2E coverage requires nyc instrumentation — see docs/coverage.md'",
    "test:coverage:merge": "npx nyc merge coverage-e2e/.nyc_output coverage/coverage-e2e.json && echo 'Merged E2E coverage into coverage/'",
    "test:coverage:report": "vitest run tests/ --coverage && npm run test:e2e && npm run test:coverage:merge",
    "test:coverage:verify": "vitest run tests/ --coverage --no-watch 2>&1 | grep -E '(Statements|Branches|Functions|Lines|ERROR|FAIL)' || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --reporter=list,html",
    "test:all": "npm run test:unit && npm run test:e2e",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "@tailwindcss/typography": "^0.5.0",
    "@prisma/client": "^5.22.0",
    "zustand": "^5.0.0",
    "@tanstack/react-query": "^5.59.0",
    "lucide-react": "^0.460.0",
    "cytoscape": "^3.30.0",
    "react-cytoscapejs": "^2.0.0",
    "date-fns": "^4.1.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "cytoscape-dagre": "^2.5.0",
    "@popperjs/core": "^2.11.0",
    "class-variance-authority": "^0.7.0",
    "next-themes": "^0.4.0",
    "cmdk": "^1.0.0",
    "framer-motion": "^11.11.0",
    "dompurify": "^3.4.1",
    "@datadog/browser-rum": "^5.34.0",
    "@sentry/nextjs": "^8.50.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "prisma": "^5.22.0",
    "@types/react-cytoscapejs": "^1.2.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/cytoscape": "^3.21.8",
    "@types/debug": "^4.1.0",
    "@types/hast": "^3.0.0",
    "@types/mdast": "^4.0.0",
    "@types/ms": "^0.7.0",
    "@types/unist": "^3.0.0",
    "@types/uuid": "^9.0.0",
    "@next/bundle-analyzer": "^15.0.0",
    "critters": "^0.0.25",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.19.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-config-prettier": "^9.1.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.6.0",
    "jsdom": "^26.0.0"
  }
}
