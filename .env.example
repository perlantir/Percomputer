# Multi-Model Agent Platform
# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_platform"

# Redis connection string
# Format: redis://HOST:PORT or rediss://HOST:PORT for TLS
REDIS_URL="redis://localhost:6379"

# NextAuth.js encryption secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Application base URL
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# AI PROVIDER API KEYS (at least one required)
# =============================================================================

# OpenAI API Key - for GPT-4, GPT-4o, GPT-3.5
OPENAI_API_KEY="sk-your-openai-key"

# Anthropic API Key - for Claude 3.5 Sonnet, Claude 3 Opus
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# Google AI API Key - for Gemini 1.5 Pro, Gemini 1.5 Flash
GOOGLE_AI_API_KEY="your-google-ai-key"

# Ollama base URL for local models (optional)
# Default: http://localhost:11434
OLLAMA_BASE_URL="http://localhost:11434"

# =============================================================================
# OPTIONAL - GENERAL
# =============================================================================

# Node environment
NODE_ENV="development"

# Server port (default: 3000)
PORT="3000"

# Logging level: debug, info, warn, error
LOG_LEVEL="info"

# =============================================================================
# OPTIONAL - RATE LIMITING
# =============================================================================

# Maximum requests per rate limit window
RATE_LIMIT_MAX="100"

# Rate limit window in milliseconds (default: 1 minute)
RATE_LIMIT_WINDOW_MS="60000"

# =============================================================================
# OPTIONAL - FEATURES
# =============================================================================

# Maximum file upload size in MB
MAX_FILE_UPLOAD_SIZE="10"

# Enable usage analytics
ENABLE_ANALYTICS="false"

# Enable advanced workflow features (beta)
ENABLE_NEW_WORKFLOW_ENGINE="false"

# Enable real-time collaboration features
ENABLE_COLLABORATION="false"

# Enable advanced analytics dashboard
ENABLE_ADVANCED_ANALYTICS="false"

# Enable beta/early-access model providers
ENABLE_BETA_MODELS="false"

# =============================================================================
# OPTIONAL - PROMETHEUS METRICS
# =============================================================================

# Enable Prometheus metrics endpoint (default: true, set to false to disable)
METRICS_ENABLED="true"

# Bearer token to protect /api/metrics endpoint (leave empty for no auth - dev only)
# Generate with: openssl rand -hex 32
METRICS_API_TOKEN=""

# Build version shown in app_build_info metric
APP_VERSION="0.1.0"

# Git commit SHA shown in app_build_info metric (auto-detected in CI)
APP_COMMIT=""

# Git branch shown in app_build_info metric (auto-detected in CI)
APP_BRANCH=""

# =============================================================================
# OPTIONAL - MONITORING
# =============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=""

# Sentry environment label (development | staging | production)
SENTRY_ENVIRONMENT="development"

# Sentry release identifier (auto-detected from git if empty)
SENTRY_RELEASE=""

# Sentry traces sample rate: 0.0 = off, 1.0 = all (default: 0.1)
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Client-side Sentry DSN (falls back to SENTRY_DSN if empty)
NEXT_PUBLIC_SENTRY_DSN=""

# Client-side Sentry environment
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# Client-side traces sample rate (default: 0.1)
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Session Replay sample rate: 0.0 = off (default, recommended for privacy)
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE="0.0"

# Sentry auth token for source map upload (CI only, never client-side)
# Get from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=""

# Sentry org slug for source map upload
SENTRY_ORG=""

# Sentry project slug for source map upload
SENTRY_PROJECT=""

# Vercel Analytics ID
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# =============================================================================
# OPTIONAL - DATADOG REAL USER MONITORING (RUM)
# =============================================================================

# Master switch: "true" to enable RUM in the browser
NEXT_PUBLIC_DD_RUM_ENABLED="false"

# Datadog RUM application ID (from your Datadog RUM app setup)
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=""

# Datadog RUM client token (NOT your API key — a client token from RUM settings)
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=""

# Datadog site — e.g. datadoghq.com, datadoghq.eu, us3.datadoghq.com, ddog-gov.com
NEXT_PUBLIC_DD_RUM_SITE="datadoghq.com"

# Environment tag shown in Datadog (dev / staging / production)
NEXT_PUBLIC_DD_RUM_ENV="development"

# Service name for RUM sessions (default: agent-platform-web)
NEXT_PUBLIC_DD_RUM_SERVICE="agent-platform-web"

# App version tag (default: 0.1.0)
NEXT_PUBLIC_DD_RUM_VERSION="0.1.0"

# Session sample rate: 0-100 (default: 100)
NEXT_PUBLIC_DD_RUM_SAMPLE_RATE="100"

# Session replay sample rate: 0-100 (default: 0)
NEXT_PUBLIC_DD_RUM_SESSION_REPLAY_SAMPLE_RATE="0"

# =============================================================================
# OPTIONAL - REDIS (Upstash for serverless)
# =============================================================================

# Upstash Redis REST URL (for serverless environments)
UPSTASH_REDIS_REST_URL=""

# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# OPTIONAL - DATABASE (for connection pooling)
# =============================================================================

# Direct database URL (for migrations, bypassing pooler)
DIRECT_DATABASE_URL=""

# =============================================================================
# OPTIONAL - AUTHENTICATION PROVIDERS
# =============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# OPTIONAL - STORAGE
# =============================================================================

# AWS S3 or compatible (for file uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_BUCKET_NAME=""

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable React Strict Mode
NEXT_PUBLIC_STRICT_MODE="true"

# Enable source maps in production
ENABLE_SOURCE_MAPS="false"

# Turbo mode for faster builds
TURBO_REMOTE_CACHE_SIGNATURE_KEY=""
