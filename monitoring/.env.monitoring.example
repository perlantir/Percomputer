# ============================================================
# Monitoring Stack - Environment Variables
# Copy to .env.monitoring and customize
# ============================================================

# --------------------------------------------------
# Grafana
# --------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_ANONYMOUS=false

# --------------------------------------------------
# Prometheus
# --------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# --------------------------------------------------
# Loki
# --------------------------------------------------
LOKI_PORT=3100

# --------------------------------------------------
# cAdvisor
# --------------------------------------------------
CADVISOR_PORT=8080

# --------------------------------------------------
# Node Exporter
# --------------------------------------------------
NODE_EXPORTER_PORT=9100

# --------------------------------------------------
# PostgreSQL Exporter
# --------------------------------------------------
POSTGRES_EXPORTER_PORT=9187
# Uses same credentials from main .env (POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB)

# --------------------------------------------------
# Redis Exporter
# --------------------------------------------------
REDIS_EXPORTER_PORT=9121

# --------------------------------------------------
# Blackbox Exporter
# --------------------------------------------------
BLACKBOX_PORT=9115

# --------------------------------------------------
# Alerting (optional)
# --------------------------------------------------
ALERT_EMAIL=admin@example.com
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=